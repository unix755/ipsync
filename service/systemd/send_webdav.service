[Unit]
Description=IP Sync Sender
After=network.target network-online.target

[Service]
Environment="I_ENDPOINT=xxx"
Environment="I_USERNAME=xxx"
Environment="I_PASSWORD=xxx"
Environment="I_FILEPATH=xxx"
Environment="I_ENCRYPTION_KEY=xxx"
Type=oneshot
User=root
ExecStart=/usr/local/bin/ipsync send webdav -endpoint=${N_ENDPOINT} -username=${N_USERNAME} -password=${N_PASSWORD} -filepath=${N_FILEPATH} -encryption_key=${N_ENCRYPTION_KEY}

[Install]
WantedBy=multi-user.target