[Unit]
Description=IP Sync WireGuard Watchdog
After=network.target network-online.target

[Service]
Environment=KEY=""
Environment=WG_REMOTE_INTERFACE=""
Environment=WG_INTERFACE=""
Environment=WEBDAV_ENDPOINT=""
Environment=WEBDAV_USERNAME=""
Environment=WEBDAV_PASSWORD=""
Environment=WEBDAV_PATH=""
Type=oneshot
User=root
ExecStart=/usr/local/bin/ipsync wireguard webdav

[Install]
WantedBy=multi-user.target
